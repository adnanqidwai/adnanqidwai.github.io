---
interface Props {
	title: string;
	description?: string;
	showNav?: boolean;
}

const { title, description = "Personal website and portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="color-scheme" content="dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>
<style is:global>
	html {
		background: #111111;
		color: #111111;
	}
	body {
		margin: 0;
		min-height: 100vh;
		background: #111111;
	}
	main {
		min-height: 100vh;
	}
	a {
		color: inherit;
	}
</style>
